<svg viewBox="0 0 1200 280" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#12101c"/>
      <stop offset="55%" stop-color="#1c1830"/>
      <stop offset="100%" stop-color="#241c38"/>
    </linearGradient>
    <filter id="glow" x="-60%" y="-60%" width="220%" height="220%">
      <feGaussianBlur stdDeviation="3.2" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M0,0 L10,5 L0,10 z" fill="#8b93bf"/>
    </marker>
  </defs>

  <rect x="0" y="0" width="1200" height="280" rx="18" fill="url(#bg)"/>

  <!-- causal graph, right side: edges with a continuous "flowing data" dash animation -->
  <g stroke="#8b93bf" stroke-opacity="0.6" stroke-width="1.6" fill="none" marker-end="url(#arrow)">
    <path d="M700,66 C740,100 760,120 778,148" stroke-dasharray="6,5">
      <animate attributeName="stroke-dashoffset" from="0" to="-22" dur="1.3s" repeatCount="indefinite"/>
    </path>
    <path d="M852,54 C820,95 800,120 780,148" stroke-dasharray="6,5">
      <animate attributeName="stroke-dashoffset" from="0" to="-22" dur="1.5s" begin="0.2s" repeatCount="indefinite"/>
    </path>
    <path d="M852,54 C890,80 920,100 948,122" stroke-dasharray="6,5">
      <animate attributeName="stroke-dashoffset" from="0" to="-22" dur="1.2s" begin="0.4s" repeatCount="indefinite"/>
    </path>
    <path d="M655,202 C700,182 740,168 778,150" stroke-dasharray="6,5">
      <animate attributeName="stroke-dashoffset" from="0" to="-22" dur="1.6s" begin="0.1s" repeatCount="indefinite"/>
    </path>
    <path d="M784,152 C830,178 858,198 896,224" stroke-dasharray="6,5">
      <animate attributeName="stroke-dashoffset" from="0" to="-22" dur="1.4s" begin="0.5s" repeatCount="indefinite"/>
    </path>
    <path d="M950,124 C975,150 1000,172 1018,198" stroke-dasharray="6,5">
      <animate attributeName="stroke-dashoffset" from="0" to="-22" dur="1.3s" begin="0.3s" repeatCount="indefinite"/>
    </path>
    <path d="M902,226 C945,218 985,210 1016,200" stroke-dasharray="6,5">
      <animate attributeName="stroke-dashoffset" from="0" to="-22" dur="1.5s" begin="0.6s" repeatCount="indefinite"/>
    </path>
  </g>

  <g filter="url(#glow)">
    <circle cx="700" cy="60" r="6" fill="#f2a765">
      <animate attributeName="r" values="5.5;7.5;5.5" dur="3.2s" repeatCount="indefinite"/>
    </circle>
    <circle cx="852" cy="50" r="6" fill="#4fd6c4">
      <animate attributeName="r" values="5.5;7.5;5.5" dur="2.6s" begin="0.4s" repeatCount="indefinite"/>
    </circle>
    <circle cx="655" cy="202" r="6" fill="#4fd6c4">
      <animate attributeName="r" values="5.5;7.5;5.5" dur="3.6s" begin="0.8s" repeatCount="indefinite"/>
    </circle>
    <circle cx="781" cy="150" r="7" fill="#f2a765">
      <animate attributeName="r" values="6.5;8.5;6.5" dur="2.4s" begin="0.2s" repeatCount="indefinite"/>
    </circle>
    <circle cx="950" cy="122" r="6" fill="#4fd6c4">
      <animate attributeName="r" values="5.5;7.5;5.5" dur="3s" begin="1s" repeatCount="indefinite"/>
    </circle>
    <circle cx="899" cy="226" r="6" fill="#f2a765">
      <animate attributeName="r" values="5.5;7.5;5.5" dur="2.8s" begin="0.6s" repeatCount="indefinite"/>
    </circle>
    <circle cx="1020" cy="200" r="7" fill="#f2a765">
      <animate attributeName="r" values="6.5;8.5;6.5" dur="2.5s" begin="1.3s" repeatCount="indefinite"/>
    </circle>
  </g>

  <!-- typography, left side -->
  <text x="52" y="118" font-family="'JetBrains Mono','Fira Code',Consolas,monospace" font-size="46" font-weight="700" letter-spacing="2" fill="#f4f4f8">LUCA NEVIANI</text>

  <text x="54" y="152" font-family="'JetBrains Mono','Fira Code',Consolas,monospace" font-size="19" fill="#aab0d6">data scientist in the making</text>
  <rect x="382" y="139" width="10" height="18" fill="#f2a765">
    <animate attributeName="opacity" values="1;1;0;0" keyTimes="0;0.5;0.51;1" dur="1.1s" repeatCount="indefinite"/>
  </rect>

  <text x="54" y="184" font-family="'JetBrains Mono','Fira Code',Consolas,monospace" font-size="14.5" letter-spacing="0.5" fill="#7a81a8">econometrics · machine learning · causal inference</text>

  <rect x="54" y="200" width="64" height="3" rx="1.5" fill="#f2a765"/>
</svg>

