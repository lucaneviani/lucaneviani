<svg viewBox="0 0 1200 280" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#12101c"/>
      <stop offset="55%" stop-color="#1c1830"/>
      <stop offset="100%" stop-color="#241c38"/>
    </linearGradient>
    <filter id="glow" x="-60%" y="-60%" width="220%" height="220%">
      <feGaussianBlur stdDeviation="3.2" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M0,0 L10,5 L0,10 z" fill="#8b93bf"/>
    </marker>
  </defs>

  <style>
    .edge{
      stroke:#8b93bf;
      stroke-opacity:0.6;
      stroke-width:1.6;
      fill:none;
      stroke-dasharray:6,5;
      animation:flow 1.4s linear infinite;
    }
    @keyframes flow{ to{ stroke-dashoffset:-22; } }

    .node{
      transform-box:fill-box;
      transform-origin:center;
      animation:pulse 2.8s ease-in-out infinite;
    }
    @keyframes pulse{
      0%,100%{ transform:scale(1); }
      50%{ transform:scale(1.35); }
    }

    .cursor{
      animation:blink 1.1s steps(1) infinite;
    }
    @keyframes blink{
      0%,50%{ opacity:1; }
      51%,100%{ opacity:0; }
    }
  </style>

  <rect x="0" y="0" width="1200" height="280" rx="18" fill="url(#bg)"/>

  <!-- causal graph, right side -->
  <g marker-end="url(#arrow)">
    <path class="edge" d="M700,66 C740,100 760,120 778,148" style="animation-delay:0s"/>
    <path class="edge" d="M852,54 C820,95 800,120 780,148" style="animation-delay:0.2s"/>
    <path class="edge" d="M852,54 C890,80 920,100 948,122" style="animation-delay:0.4s"/>
    <path class="edge" d="M655,202 C700,182 740,168 778,150" style="animation-delay:0.1s"/>
    <path class="edge" d="M784,152 C830,178 858,198 896,224" style="animation-delay:0.5s"/>
    <path class="edge" d="M950,124 C975,150 1000,172 1018,198" style="animation-delay:0.3s"/>
    <path class="edge" d="M902,226 C945,218 985,210 1016,200" style="animation-delay:0.6s"/>
  </g>

  <g filter="url(#glow)">
    <circle class="node" cx="700" cy="60" r="6" fill="#f2a765" style="animation-delay:0s"/>
    <circle class="node" cx="852" cy="50" r="6" fill="#4fd6c4" style="animation-delay:0.4s"/>
    <circle class="node" cx="655" cy="202" r="6" fill="#4fd6c4" style="animation-delay:0.8s"/>
    <circle class="node" cx="781" cy="150" r="7" fill="#f2a765" style="animation-delay:0.2s"/>
    <circle class="node" cx="950" cy="122" r="6" fill="#4fd6c4" style="animation-delay:1s"/>
    <circle class="node" cx="899" cy="226" r="6" fill="#f2a765" style="animation-delay:0.6s"/>
    <circle class="node" cx="1020" cy="200" r="7" fill="#f2a765" style="animation-delay:1.3s"/>
  </g>

  <!-- typography, left side -->
  <text x="52" y="118" font-family="'JetBrains Mono','Fira Code',Consolas,monospace" font-size="46" font-weight="700" letter-spacing="2" fill="#f4f4f8">LUCA NEVIANI</text>

  <text x="54" y="152" font-family="'JetBrains Mono','Fira Code',Consolas,monospace" font-size="19" fill="#aab0d6">data scientist in the making</text>
  <rect class="cursor" x="382" y="139" width="10" height="18" fill="#f2a765"/>

  <text x="54" y="184" font-family="'JetBrains Mono','Fira Code',Consolas,monospace" font-size="14.5" letter-spacing="0.5" fill="#7a81a8">econometrics · machine learning · causal inference</text>

  <rect x="54" y="200" width="64" height="3" rx="1.5" fill="#f2a765"/>
</svg>
